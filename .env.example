# Copy to .env and fill in. Never commit .env.
#
# CLOB signing (tyrex-pm run live / live-attest):
#   Prefer TYREX_*; POLYMARKET_* are accepted as fallbacks.
# TYREX_PRIVATE_KEY=
# TYREX_FUNDER=
# POLYMARKET_PK=
# POLYMARKET_FUNDER=
#
# TYREX_CLOB_HOST=https://clob.polymarket.com
# TYREX_CHAIN_ID=137
# TYREX_SIGNATURE_TYPE=0
# POLYMARKET_SIGNATURE_TYPE=   # fallback alias for TYREX_SIGNATURE_TYPE (e.g. 1 = proxy)
# TYREX_HEARTBEAT_ID=   # optional; hyphenated UUIDs are normalized to 32-char hex
# POLYMARKET_HEARTBEAT_ID=   # fallback alias for TYREX_HEARTBEAT_ID
#
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_PASSPHRASE=
#
# Provisional repair state machine (optional overrides; see config/runtime/default.yaml supervisors):
# TYREX_SUBMIT_GRACE_S=15                          # provisional row absent below this is non-blocking
# TYREX_PROVISIONAL_UNKNOWN_TERMINAL_TIMEOUT_S=60  # past this (with WS fresh + no restart) → UNKNOWN_TERMINAL drop
# Back-compat aliases (still honored if the new ones are unset):
# TYREX_VENUE_CONFIRM_GRACE_S=15
# TYREX_VENUE_CONFIRM_PROVISIONAL_TIMEOUT_S=60
# TYREX_ADOPTION_GRACE_S=5  # venue-truth mirror race: adopt fresh REST/WS order ids onto recent no-vid local rows

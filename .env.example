# Copy to `.env` and fill in. Never commit real values.
# Precedence: existing shell/CI environment variables ALWAYS override these entries.

POLYMARKET_PK=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=2

# Optional: full L2 triple (omit all three to derive via L1 using POLYMARKET_PK instead)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Optional overrides
# POLYMARKET_CLOB_HOST=https://clob.polymarket.com
# POLYMARKET_CHAIN_ID=137
# TYREX_PM_DOTENV=path\to\custom.env
